generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_DEV_URL")
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum ShiftStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum SwapStatus {
  PENDING
  ACCEPTED
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
}

enum DropStatus {
  PENDING
  CLAIMED
  EXPIRED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(STAFF)
  timezone     String   @default("America/New_York")
  desiredHours Int      @default(40)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  locationCertifications UserLocation[]
  skills                 UserSkill[]
  availability           Availability[]
  assignedShifts         ShiftAssignment[] @relation("AssignedBy")
  swapRequestsRequested  SwapRequest[]     @relation("SwapRequester")
  swapRequestsTarget     SwapRequest[]     @relation("SwapTarget")
  dropRequests           DropRequest[]
  notifications          Notification[]
  auditLogs              AuditLog[]
  shiftAssignments       ShiftAssignment[]
}

model Location {
  id          String   @id @default(cuid())
  name        String
  address     String
  timezone    String
  cutoffHours Int      @default(48)
  createdAt   DateTime @default(now())

  shifts   Shift[]
  managers UserLocation[]
}

model UserLocation {
  id         String   @id @default(cuid())
  userId     String
  locationId String
  isManager  Boolean  @default(false)
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([userId, locationId])
}

model Skill {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  shifts     Shift[]
  userSkills UserSkill[]
}

model UserSkill {
  id        String   @id @default(cuid())
  userId    String
  skillId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
}

model Availability {
  id           String    @id @default(cuid())
  userId       String
  dayOfWeek    Int?
  startTime    String
  endTime      String
  isRecurring  Boolean   @default(true)
  specificDate DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Shift {
  id              String      @id @default(cuid())
  locationId      String
  startTime       DateTime
  endTime         DateTime
  requiredSkillId String
  headcount       Int         @default(1)
  status          ShiftStatus @default(DRAFT)
  publishedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  location      Location          @relation(fields: [locationId], references: [id], onDelete: Cascade)
  requiredSkill Skill             @relation(fields: [requiredSkillId], references: [id], onDelete: Cascade)
  assignments   ShiftAssignment[]
  swapRequests  SwapRequest[]
  dropRequests  DropRequest[]

  @@index([locationId])
  @@index([status])
  @@index([startTime])
}

model ShiftAssignment {
  id         String   @id @default(cuid())
  shiftId    String
  staffId    String
  assignedBy String
  version    Int      @default(1)
  createdAt  DateTime @default(now())

  shift    Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  staff    User  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  assigner User  @relation("AssignedBy", fields: [assignedBy], references: [id], onDelete: Cascade)

  @@unique([shiftId, staffId])
  @@index([shiftId])
  @@index([staffId])
}

model SwapRequest {
  id          String     @id @default(cuid())
  shiftId     String
  requesterId String
  targetId    String?
  status      SwapStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  shift     Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  requester User  @relation("SwapRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  target    User? @relation("SwapTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([shiftId])
  @@index([requesterId])
  @@index([status])
}

model DropRequest {
  id          String     @id @default(cuid())
  shiftId     String
  requesterId String
  status      DropStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  shift     Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  requester User  @relation(fields: [requesterId], references: [id], onDelete: Cascade)

  @@index([shiftId])
  @@index([requesterId])
  @@index([status])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  read      Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
